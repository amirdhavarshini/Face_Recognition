    "# ============ 6. PYTORCH DATASET ============\n",
    "\n",
    "TOKEN2ID = {\"A\": 1, \"C\": 2, \"G\": 3, \"U\": 4, \"N\": 5}\n",
    "PAD_ID = 0\n",
    "\n",
    "def tokenize(seq, max_len):\n",
    "    ids = [TOKEN2ID.get(c, 5) for c in seq[:max_len]]\n",
    "    ids += [PAD_ID] * (max_len - len(ids))\n",
    "    return np.array(ids, dtype=np.int64)\n",
    "\n",
    "class RNADataset(Dataset):\n",
    "    def __init__(self, seq_df, lbl_df, max_len=CFG.MAX_LEN):\n",
    "        self.max_len = max_len\n",
    "        self.items = []\n",
    "        lbl_df = lbl_df.copy()\n",
    "        lbl_df[\"target_id\"] = lbl_df[\"ID\"].str.split(\"_\").str[0]\n",
    "\n",
    "        # Group ONCE instead of re-filtering the whole dataframe per target -- this is the\n",
    "        # fix. The old version scanned all of train_labels.csv for every single target,\n",
    "        # which is fine for ~150 debug targets but explodes on the full dataset.\n",
    "        grouped = dict(list(lbl_df.groupby(\"target_id\")))\n",
    "\n",
    "        for tid, seq in zip(seq_df[\"target_id\"], seq_df[\"sequence\"]):\n",
    "            g = grouped.get(tid)\n",
    "            if g is None or len(g) == 0:\n",
    "                continue\n",
    "            g = g.sort_values(\"resid\")\n",
    "            coords = g[[\"x_1\", \"y_1\", \"z_1\"]].to_numpy(dtype=np.float32)\n",
    "            valid = ~np.isnan(coords).any(axis=1)\n",
    "            if valid.sum() == 0:\n",
    "                continue\n",
    "            coords[valid] -= coords[valid].mean(axis=0)\n",
    "            self.items.append((tid, seq, coords))\n",
    "\n",
    "    def __len__(self):\n",
    "        return len(self.items)\n",
    "\n",
    "    def __getitem__(self, idx):\n",
    "        tid, seq, coords = self.items[idx]\n",
    "        L = min(len(seq), self.max_len)\n",
    "        token_ids = tokenize(seq, self.max_len)\n",
    "        xyz = np.zeros((self.max_len, 3), dtype=np.float32)\n",
    "        mask = np.zeros(self.max_len, dtype=np.float32)\n",
    "        n = min(L, len(coords))\n",
    "        if n > 0:\n",
    "            c = coords[:n]\n",
    "            valid = ~np.isnan(c).any(axis=1)\n",
    "            xyz[:n][valid] = c[valid]\n",
    "            mask[:n][valid] = 1.0\n",
    "        rna_fm = np.zeros((self.max_len, RNA_FM_DIM), dtype=np.float32)\n",
    "        emb = get_rna_fm_embedding(tid, seq)[:L]\n",
    "        rna_fm[:L] = emb\n",
