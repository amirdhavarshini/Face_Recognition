    "# ============ 7. MODEL ============\n",
    "\n",
    "class PositionalEncoding(nn.Module):\n",
    "    def __init__(self, d_model, max_len):\n",
    "        super().__init__()\n",
    "        pe = torch.zeros(max_len, d_model)\n",
    "        pos = torch.arange(0, max_len).unsqueeze(1).float()\n",
    "        div = torch.exp(torch.arange(0, d_model, 2).float() * (-math.log(10000.0) / d_model))\n",
    "        pe[:, 0::2] = torch.sin(pos * div)\n",
    "        pe[:, 1::2] = torch.cos(pos * div)\n",
    "        self.register_buffer(\"pe\", pe.unsqueeze(0))\n",
    "\n",
    "    def forward(self, x):\n",
    "        return x + self.pe[:, :x.size(1)]\n",
    "\n",
    "class SimpleGNNLayer(nn.Module):\n",
    "    def __init__(self, d_model, k_neighbors=2):\n",
    "        super().__init__()\n",
    "        self.k = k_neighbors\n",
    "        self.lin = nn.Linear(d_model, d_model)\n",
    "        self.norm = nn.LayerNorm(d_model)\n",
    "\n",
    "    def forward(self, x, mask):\n",
    "        B, L, D = x.shape\n",
    "        agg = torch.zeros_like(x)\n",
    "        for shift in range(1, self.k + 1):\n",
    "            agg[:, shift:, :] += x[:, :-shift, :]\n",
    "            agg[:, :-shift, :] += x[:, shift:, :]\n",
    "        agg = agg / (2 * self.k)\n",
    "        out = self.norm(x + F.relu(self.lin(agg)))\n",
    "        return out * mask.unsqueeze(-1)\n",
    "\n",
    "class RNAStructureModel(nn.Module):\n",
    "    def __init__(self, cfg=CFG):\n",
    "        super().__init__()\n",
    "        self.embed = nn.Embedding(len(TOKEN2ID) + 1, cfg.D_MODEL, padding_idx=PAD_ID)\n",
    "        self.rna_fm_proj = nn.Linear(RNA_FM_DIM, cfg.D_MODEL)\n",
    "        self.pos_enc = PositionalEncoding(cfg.D_MODEL, cfg.MAX_LEN)\n",
    "        enc_layer = nn.TransformerEncoderLayer(\n",
    "            d_model=cfg.D_MODEL, nhead=cfg.N_HEADS, dim_feedforward=cfg.D_MODEL * 4,\n",
    "            dropout=cfg.DROPOUT, batch_first=True\n",
    "        )\n",
    "        self.transformer = nn.TransformerEncoder(enc_layer, num_layers=cfg.N_TRANSFORMER_LAYERS)\n",
    "        self.gnn_layers = nn.ModuleList([SimpleGNNLayer(cfg.D_MODEL) for _ in range(cfg.N_GNN_LAYERS)])\n",
    "        self.head = nn.Sequential(\n",
    "            nn.Linear(cfg.D_MODEL, cfg.D_MODEL // 2), nn.ReLU(),\n",
    "            nn.Linear(cfg.D_MODEL // 2, 3)\n",
    "        )\n",
    "\n",
    "    def forward(self, tokens, mask, rna_fm=None):\n",
    "        x = self.embed(tokens)\n",
    "        if rna_fm is not None:\n",
    "            x = x + self.rna_fm_proj(rna_fm)\n",
    "        x = self.pos_enc(x)\n",
    "        pad_mask = (mask == 0)\n",
    "        x = self.transformer(x, src_key_padding_mask=pad_mask)\n",
    "        for gnn in self.gnn_layers:\n",
    "            x = gnn(x, mask)\n",
    "        coords = self.head(x)\n",
    "        return coords * mask.unsqueeze(-1)\n",
    "\n",
    "model = RNAStructureModel().to(DEVICE)\n",
    "n_params = sum(p.numel() for p in model.parameters())\n",
    "print(f\"Model created -- {n_params:,} parameters\")"
