    "def predict_conformations(seq, tid=\"test\", n_conf=CFG.N_CONFORMATIONS):\n",
    "    \"\"\"Diversity now comes from MC-dropout (dropout kept active at inference) instead of\n",
    "    arbitrary Gaussian noise -- a more principled way to sample plausible conformations.\"\"\"\n",
    "    def _predict_once(dropout_on):\n",
    "        model.train(dropout_on)\n",
    "        chunks = []\n",
    "        for start in range(0, len(seq), CFG.MAX_LEN):\n",
    "            chunk_seq = seq[start:start + CFG.MAX_LEN]\n",
    "            L = len(chunk_seq)\n",
    "            tokens = torch.from_numpy(tokenize(chunk_seq, CFG.MAX_LEN)).unsqueeze(0).to(DEVICE)\n",
    "            mask = torch.zeros(1, CFG.MAX_LEN, device=DEVICE); mask[0, :L] = 1.0\n",
    "            rna_fm = torch.zeros(1, CFG.MAX_LEN, RNA_FM_DIM, device=DEVICE)\n",
    "            emb = get_rna_fm_embedding(tid, chunk_seq)\n",
    "            rna_fm[0, :L] = torch.from_numpy(emb).to(DEVICE)\n",
    "            with torch.no_grad():\n",
    "                chunks.append(model(tokens, mask, rna_fm)[0, :L].cpu().numpy())\n",
    "        return np.concatenate(chunks, axis=0)\n",
    "\n",
    "    base = _predict_once(dropout_on=False)\n",
    "    conformations = [base]\n",
    "    for _ in range(n_conf - 1):\n",
    "        conformations.append(_predict_once(dropout_on=True))\n",
    "    model.eval()\n",
    "    return conformations\n",
    "\n",
    "if len(test_seq) > 0:\n",
    "    n_long = (test_seq[\"sequence\"].str.len() > CFG.MAX_LEN).sum()\n",
    "    if n_long > 0:\n",
    "        print(f\"[INFO] {n_long} test sequence(s) exceed MAX_LEN and will be predicted in chunks.\")\n",
    "    rows = []\n",
    "    for tid, seq in zip(test_seq[\"target_id\"], test_seq[\"sequence\"]):\n",
    "        confs = predict_conformations(seq, tid=tid)\n",
    "        for resid in range(len(seq)):\n",
    "            row = {\"ID\": f\"{tid}_{resid+1}\", \"resname\": seq[resid], \"resid\": resid + 1}\n",
    "            for c_idx, conf in enumerate(confs, start=1):\n",
    "                row[f\"x_{c_idx}\"], row[f\"y_{c_idx}\"], row[f\"z_{c_idx}\"] = conf[resid]\n",
    "            rows.append(row)\n",
    "    submission = pd.DataFrame(rows)\n",
    "    submission.to_csv(f\"{CFG.OUT_DIR}/submission.csv\", index=False)\n",
    "    print(\"Saved submission.csv:\", submission.shape)"
   ]
