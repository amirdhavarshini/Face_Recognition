    "# ============ 10. EVALUATION ============\n",
    "\n",
    "def kabsch_align(pred, true):\n",
    "    \"\"\"Optimal rotation+translation alignment (Kabsch algorithm), then return the RMSD.\"\"\"\n",
    "    pred_c = pred - pred.mean(0)\n",
    "    true_c = true - true.mean(0)\n",
    "    H = pred_c.T @ true_c\n",
    "    U, S, Vt = np.linalg.svd(H)\n",
    "    d = np.sign(np.linalg.det(Vt.T @ U.T))\n",
    "    D = np.diag([1, 1, d])\n",
    "    R = Vt.T @ D @ U.T\n",
    "    pred_aligned = (R @ pred_c.T).T\n",
    "    rmsd = np.sqrt(((pred_aligned - true_c) ** 2).sum(-1).mean())\n",
    "    return rmsd\n",
    "\n",
    "def tm_score_approx(pred, true, d0=5.0):\n",
    "    \"\"\"Simplified TM-score (length-normalised, no reference-length correction term) --\n",
    "    useful as a relative ranking metric between epochs/models, not a competition-exact score.\"\"\"\n",
    "    rmsd_per_res = np.sqrt(((pred - true) ** 2).sum(-1))\n",
    "    return np.mean(1 / (1 + (rmsd_per_res / d0) ** 2))\n",
    "\n",
    "model.eval()\n",
    "rmsd_records = []\n",
    "with torch.no_grad():\n",
    "    for batch in val_loader:\n",
    "        tokens = batch[\"tokens\"].to(DEVICE); mask = batch[\"mask\"].to(DEVICE)\n",
    "        rna_fm = batch[\"rna_fm\"].to(DEVICE)\n",
    "        pred = model(tokens, mask, rna_fm).cpu().numpy()\n",
    "        xyz = batch[\"xyz\"].numpy()\n",
    "        m = batch[\"mask\"].numpy()\n",
    "        for i, tid in enumerate(batch[\"target_id\"]):\n",
    "            L = int(m[i].sum())\n",
    "            if L < 3:\n",
    "                continue\n",
    "            p, t = pred[i, :L], xyz[i, :L]\n",
    "            rmsd_records.append({\"target_id\": tid, \"seq_len\": L, \"rmsd\": kabsch_align(p, t), \"tm_approx\": tm_score_approx(p, t)})\n",
    "\n",
    "rmsd_df = pd.DataFrame(rmsd_records)\n",
    "print(f\"Validation RMSD: mean={rmsd_df['rmsd'].mean():.2f} A | median={rmsd_df['rmsd'].median():.2f} A\")\n",
