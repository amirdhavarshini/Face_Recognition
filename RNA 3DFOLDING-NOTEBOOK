    "# ============ 5c. Secondary structure features (optional, auto-skips if ViennaRNA missing) ============\n",
    "# On Kaggle: add ViennaRNA via `!pip install ViennaRNA -q` in a cell above if this prints \"not available\".\n",
    "\n",
    "try:\n",
    "    import RNA  # ViennaRNA python bindings\n",
    "    HAS_VIENNA = True\n",
    "except ImportError:\n",
    "    HAS_VIENNA = False\n",
    "    print(\"[INFO] ViennaRNA not installed -> secondary-structure features will be zero-filled. \"\n",
    "          \"Run `!pip install ViennaRNA -q` in a cell above to enable this block.\")\n",
    "\n",
    "def secondary_structure_features(seq):\n",
    "    if not (HAS_VIENNA and CFG.USE_SECONDARY_STRUCTURE):\n",
    "        return {\"mfe\": 0.0, \"paired_fraction\": 0.0}\n",
    "    struct, mfe = RNA.fold(seq)\n",
    "    paired_fraction = sum(c in \"()\" for c in struct) / len(struct)\n",
    "    return {\"mfe\": mfe, \"paired_fraction\": paired_fraction}\n",
    "\n",
    "ss_feat_df = pd.DataFrame([\n",
    "    {\"target_id\": tid, **secondary_structure_features(s)}\n",
    "    for tid, s in zip(train_seq[\"target_id\"], train_seq[\"sequence\"])\n",
    "])\n",
    "ss_feat_df.head(3)\n"
   ]
