    "# ============ 4. EDA ============\n",
    "\n",
    "train_seq[\"seq_len\"] = train_seq[\"sequence\"].str.len()\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(16, 4))\n",
    "\n",
    "# (a) sequence length distribution -> tells us how big MAX_LEN needs to be\n",
    "axes[0].hist(train_seq[\"seq_len\"], bins=40, color=\"steelblue\")\n",
    "axes[0].set_title(\"Sequence length distribution\")\n",
    "axes[0].set_xlabel(\"length (nt)\")\n",
    "\n",
    "# (b) nucleotide composition across the whole training set\n",
    "all_nt = \"\".join(train_seq[\"sequence\"].tolist())\n",
    "comp = pd.Series(list(all_nt)).value_counts(normalize=True)\n",
    "axes[1].bar(comp.index, comp.values, color=\"seagreen\")\n",
    "axes[1].set_title(\"Nucleotide composition (A/C/G/U)\")\n",
    "\n",
    "# (c) how many residues per target actually have 3D labels\n",
    "lbl_counts = train_lbl[\"ID\"].str.split(\"_\").str[0].value_counts()\n",
