    "# ============ 3. LOAD DATA ============\n",
    "# Standard Stanford RNA 3D Folding file layout. Wrapped defensively so a slightly\n",
    "# different column set (e.g. Part 2 vs Part 1) doesn't crash the whole notebook.\n",
    "\n",
    "def safe_read_csv(path):\n",
    "    if os.path.exists(path):\n",
    "        return pd.read_csv(path)\n",
    "    print(f\"[WARN] missing file: {path}\")\n",
    "    return pd.DataFrame()\n",
    "\n",
    "train_seq   = safe_read_csv(f\"{CFG.DATA_DIR}/train_sequences.csv\")\n",
    "train_lbl   = safe_read_csv(f\"{CFG.DATA_DIR}/train_labels.csv\")\n",
    "test_seq    = safe_read_csv(f\"{CFG.DATA_DIR}/test_sequences.csv\")\n",
    "sample_sub  = safe_read_csv(f\"{CFG.DATA_DIR}/sample_submission.csv\")\n",
    "\n",
    "print(\"train_sequences:\", train_seq.shape)\n",
    "print(\"train_labels   :\", train_lbl.shape)\n",
    "print(\"test_sequences :\", test_seq.shape)\n",
    "print(\"sample_sub     :\", sample_sub.shape)\n",
    "train_seq.head()\n"
   ]
