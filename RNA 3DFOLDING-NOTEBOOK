    "# ============ 5a. Sequence composition + k-mer features ============\n",
    "# Fast, pure-Python/vectorised -- no external tools needed.\n",
    "\n",
    "NT = [\"A\", \"C\", \"G\", \"U\"]\n",
    "\n",
    "def kmer_features(seq, k):\n",
    "    # returns normalised frequency of every k-mer of length k\n",
    "    from itertools import product\n",
    "    kmers = [\"\".join(p) for p in product(NT, repeat=k)]\n",
    "    counts = {km: 0 for km in kmers}\n",
    "    n = 0\n",
    "    for i in range(len(seq) - k + 1):\n",
    "        km = seq[i:i+k]\n",
    "        if km in counts:\n",
    "            counts[km] += 1\n",
    "            n += 1\n",
    "    return {f\"kmer{k}_{km}\": (counts[km] / n if n else 0) for km in kmers}\n",
    "\n",
    "def composition_features(seq):\n",
    "    n = len(seq)\n",
    "    comp = {f\"frac_{nt}\": seq.count(nt) / n for nt in NT}\n",
    "    comp[\"gc_content\"] = (seq.count(\"G\") + seq.count(\"C\")) / n\n",
    "    comp[\"length\"] = n\n",
    "    return comp\n",
    "\n",
    "def build_seq_features(seq):\n",
    "    feats = {}\n",
    "    feats.update(composition_features(seq))\n",
    "    for k in CFG.KMER_K:\n",
    "        feats.update(kmer_features(seq, k))\n",
    "    return feats\n",
    "\n",
    "seq_feat_df = pd.DataFrame([build_seq_features(s) for s in train_seq[\"sequence\"]])\n",
    "seq_feat_df[\"target_id\"] = train_seq[\"target_id\"].values\n",
    "print(\"Composition/k-mer features:\", seq_feat_df.shape[1] - 1, \"columns\")\n",
    "seq_feat_df.head(3)\n"
   ]
