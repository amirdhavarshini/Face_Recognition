    "# ============ 13. INTERACTIVE 3D VISUALISATION ============\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "def plot_structure(target_id, pred_xyz, true_xyz=None):\n",
    "    fig = go.Figure()\n",
    "    fig.add_trace(go.Scatter3d(\n",
    "        x=pred_xyz[:,0], y=pred_xyz[:,1], z=pred_xyz[:,2],\n",
    "        mode=\"lines+markers\", marker=dict(size=3, color=\"crimson\"),\n",
    "        line=dict(color=\"crimson\"), name=\"Predicted\"\n",
    "    ))\n",
    "    if true_xyz is not None:\n",
    "        fig.add_trace(go.Scatter3d(\n",
    "            x=true_xyz[:,0], y=true_xyz[:,1], z=true_xyz[:,2],\n",
    "            mode=\"lines+markers\", marker=dict(size=3, color=\"steelblue\"),\n",
    "            line=dict(color=\"steelblue\"), name=\"Ground truth\"\n",
    "        ))\n",
    "    fig.update_layout(title=f\"RNA 3D structure -- {target_id}\", height=600,\n",
    "                       scene=dict(xaxis_title=\"x\", yaxis_title=\"y\", zaxis_title=\"z\"))\n",
    "    fig.show()\n",
    "\n",
    "# Example: visualise the first validation target\n",
    "sample_batch = next(iter(val_loader))\n",
    "tokens = sample_batch[\"tokens\"][:1].to(DEVICE)\n",
    "mask = sample_batch[\"mask\"][:1].to(DEVICE)\n",
    "with torch.no_grad():\n",
    "    pred = model(tokens, mask)[0].cpu().numpy()\n",
    "L = int(sample_batch[\"mask\"][0].sum())\n",
    "plot_structure(sample_batch[\"target_id\"][0], pred[:L], sample_batch[\"xyz\"][0, :L].numpy())\n"
   ]
