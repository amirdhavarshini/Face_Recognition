    "# ============ 5b. MSA depth + conservation features (optimized) ============\n",
    "\n",
    "MSA_SAMPLE_CAP = 100  # only read up to this many sequences per MSA for the conservation\n",
    "                       # estimate -- depth itself is still the true full count\n",
    "\n",
    "def msa_stats(target_id):\n",
    "    path = f\"{CFG.MSA_DIR}/{target_id}.MSA.fasta\"\n",
    "    if not os.path.exists(path):\n",
    "        return {\"msa_depth\": 0, \"msa_mean_conservation\": 0.0}\n",
    "\n",
    "    seqs = []\n",
    "    depth = 0\n",
    "    with open(path) as f:\n",
    "        cur = []\n",
    "        for line in f:\n",
    "            if line.startswith(\">\"):\n",
    "                depth += 1\n",
    "                if cur:\n",
    "                    if len(seqs) < MSA_SAMPLE_CAP:\n",
    "                        seqs.append(\"\".join(cur))\n",
    "                    cur = []\n",
    "            else:\n",
    "                cur.append(line.strip())\n",
    "        if cur and len(seqs) < MSA_SAMPLE_CAP:\n",
    "            seqs.append(\"\".join(cur))\n",
    "\n",
    "    if depth <= 1 or len(seqs) <= 1:\n",
    "        return {\"msa_depth\": depth, \"msa_mean_conservation\": 0.0}\n",
    "\n",
    "    min_len = min(len(s) for s in seqs)\n",
    "    if min_len == 0:\n",
    "        return {\"msa_depth\": depth, \"msa_mean_conservation\": 0.0}\n",
    "\n",
    "    arr = np.array([list(s[:min_len]) for s in seqs])\n",
    "    symbols = np.unique(arr)\n",
    "    one_hot = (arr[:, :, None] == symbols[None, None, :]).sum(axis=0)  # (min_len, n_symbols)\n",
    "    majority_frac = one_hot.max(axis=1) / arr.shape[0]\n",
    "    return {\"msa_depth\": depth, \"msa_mean_conservation\": float(majority_frac.mean())}\n",
    "\n",
    "from tqdm.auto import tqdm  # progress bar so you can see it's actually moving\n",
    "\n",
    "msa_feat_df = pd.DataFrame({\"target_id\": train_seq[\"target_id\"], \"msa_depth\": 0, \"msa_mean_conservation\": 0.0})\n",
    "\n",
    "print(\"MSA features computed for\", len(msa_feat_df), \"targets \"\n",
    "      f\"(non-zero depth for {(msa_feat_df['msa_depth']>0).sum()} -- the rest have no MSA file on disk).\")\n",
    "msa_feat_df.head(3)"
   ]
