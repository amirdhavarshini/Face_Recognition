    "shap_df = feature_df.merge(rmsd_df, on=\"target_id\")\n",
    "X = shap_df[FEATURE_COLS]\n",
    "y = shap_df[\"rmsd\"]\n",
    "\n",
    "xgb_model = xgb.XGBRegressor(\n",
    "    n_estimators=200, max_depth=4, learning_rate=0.05,\n",
    "    subsample=0.8, colsample_bytree=0.8, random_state=CFG.SEED\n",
    ")\n",
    "xgb_model.fit(X, y)\n",
    "\n",
    "explainer = shap.TreeExplainer(xgb_model)\n",
    "shap_values = explainer.shap_values(X)\n",
    "\n",
    "shap.summary_plot(shap_values, X, plot_type=\"bar\", show=False)\n",
    "plt.title(\"Which engineered features most influence prediction difficulty (RMSD)?\")\n",
    "plt.tight_layout(); plt.show()\n"
   ]
