    "# ============ 8. LOSS ============\n",
    "\n",
    "def coordinate_loss(pred, target, mask):\n",
    "    diff2 = ((pred - target) ** 2).sum(-1)\n",
    "    return (diff2 * mask).sum() / mask.sum().clamp(min=1)\n",
    "\n",
    "def pairwise_distance_loss(pred, target, mask, max_pairs=64):\n",
    "    \"\"\"Vectorized across the whole batch at once -- no Python loop over samples, no\n",
    "    per-sample torch.randint/nonzero calls. Those were forcing many small GPU ops with\n",
    "    CPU<->GPU syncs between them, which is what was making this slow.\"\"\"\n",
    "    B, L, _ = pred.shape\n",
    "    device = pred.device\n",
    "\n",
    "    idx_i = torch.randint(0, L, (B, max_pairs), device=device)\n",
    "    idx_j = torch.randint(0, L, (B, max_pairs), device=device)\n",
    "\n",
    "    # zero out any pair touching a padded position, instead of filtering per-sample\n",
    "    m_i = torch.gather(mask, 1, idx_i)\n",
    "    m_j = torch.gather(mask, 1, idx_j)\n",
    "    valid = m_i * m_j  # (B, max_pairs), 1 where both residues are real\n",
    "\n",
    "    idx_i_exp = idx_i.unsqueeze(-1).expand(-1, -1, 3)\n",
    "    idx_j_exp = idx_j.unsqueeze(-1).expand(-1, -1, 3)\n",
    "\n",
    "    pred_i, pred_j = torch.gather(pred, 1, idx_i_exp), torch.gather(pred, 1, idx_j_exp)\n",
    "    true_i, true_j = torch.gather(target, 1, idx_i_exp), torch.gather(target, 1, idx_j_exp)\n",
    "\n",
    "    d_pred = torch.norm(pred_i - pred_j, dim=-1)\n",
    "    d_true = torch.norm(true_i - true_j, dim=-1)\n",
    "\n",
    "    sq_err = ((d_pred - d_true) ** 2) * valid\n",
    "    return sq_err.sum() / valid.sum().clamp(min=1)\n",
    "\n",
    "def total_loss(pred, target, mask):\n",
    "    c_loss = coordinate_loss(pred, target, mask)\n",
    "    d_loss = pairwise_distance_loss(pred, target, mask)\n",
    "    return c_loss + CFG.DIST_LOSS_WEIGHT * d_loss, c_loss.item(), d_loss.item()"
   ]
  },
