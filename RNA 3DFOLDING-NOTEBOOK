    "# ============ 9. TRAIN ============\n",
    "\n",
    "optimizer = torch.optim.AdamW(model.parameters(), lr=CFG.LR, weight_decay=CFG.WEIGHT_DECAY)\n",
    "scheduler = torch.optim.lr_scheduler.CosineAnnealingLR(optimizer, T_max=CFG.EPOCHS)\n",
    "scaler = torch.cuda.amp.GradScaler(enabled=(DEVICE.type == \"cuda\"))\n",
    "\n",
    "def run_epoch(loader, train=True):\n",
    "    model.train() if train else model.eval()\n",
    "    total, c_total, d_total, n_batches = 0.0, 0.0, 0.0, 0\n",
    "    for batch in loader:\n",
    "        tokens = batch[\"tokens\"].to(DEVICE)\n",
    "        mask   = batch[\"mask\"].to(DEVICE)\n",
    "        xyz    = batch[\"xyz\"].to(DEVICE)\n",
    "        rna_fm = batch[\"rna_fm\"].to(DEVICE)\n",
    "\n",
    "        with torch.set_grad_enabled(train), torch.cuda.amp.autocast(enabled=(DEVICE.type == \"cuda\")):\n",
    "            pred = model(tokens, mask, rna_fm)\n",
    "            loss, c_loss, d_loss = total_loss(pred, xyz, mask)\n",
    "\n",
    "        # Defensive guard: skip any batch that produces NaN/inf instead of letting it poison\n",
    "        # every epoch average from here on. If this fires a lot, something upstream (bad labels,\n",
    "        # exploding gradients) needs investigating rather than papering over.\n",
    "        if not torch.isfinite(loss):\n",
    "            print(f\"[WARN] non-finite loss on a batch -- skipping it\")\n",
    "            continue\n",
    "\n",
    "        if train:\n",
    "            optimizer.zero_grad()\n",
    "            scaler.scale(loss).backward()\n",
    "            scaler.unscale_(optimizer)\n",
    "            torch.nn.utils.clip_grad_norm_(model.parameters(), CFG.GRAD_CLIP)\n",
    "            scaler.step(optimizer)\n",
    "            scaler.update()\n",
    "\n",
    "        total += loss.item(); c_total += c_loss; d_total += d_loss; n_batches += 1\n",
    "    return total / max(n_batches,1), c_total / max(n_batches,1), d_total / max(n_batches,1)\n",
    "\n",
    "best_val, patience_ctr = float(\"inf\"), 0\n",
    "history = []\n",
    "for epoch in range(CFG.EPOCHS):\n",
    "    t0 = time.time()\n",
    "    tr_loss, tr_c, tr_d = run_epoch(train_loader, train=True)\n",
    "    val_loss, val_c, val_d = run_epoch(val_loader, train=False)\n",
    "    scheduler.step()\n",
    "    history.append({\"epoch\": epoch, \"train_loss\": tr_loss, \"val_loss\": val_loss})\n",
    "    print(f\"Epoch {epoch+1}/{CFG.EPOCHS} | train {tr_loss:.3f} ( coord {tr_c:.3f}, dist {tr_d:.3f}) \"\n",
    "          f\"| val {val_loss:.3f} (coord {val_c:.3f}, dist {val_d:.3f}) | {time.time()-t0:.1f}s\")\n",
    "\n",
    "    if val_loss < best_val:\n",
    "        best_val, patience_ctr = val_loss, 0\n",
    "        torch.save(model.state_dict(), f\"{CFG.OUT_DIR}/best_model.pt\")\n",
    "    else:\n",
    "        patience_ctr += 1\n",
    "        if patience_ctr >= CFG.PATIENCE:\n",
    "            print(\"Early stopping.\"); break\n",
    "\n",
    "ckpt_path = f\"{CFG.OUT_DIR}/best_model.pt\"\n",
    "if os.path.exists(ckpt_path):\n",
    "    model.load_state_dict(torch.load(ckpt_path))\n",
    "    print(\"Loaded best checkpoint.\")\n",
    "else:\n",
    "    print(\"[WARN] no checkpoint was saved -- val loss never improved on finite values. \"\n",
    "          \"Using the current (last-epoch) weights instead. If this happens, check the \"\n",
    "          \"'non-finite loss' warnings above.\")\n",
    "\n",
    "pd.DataFrame(history).plot(x=\"epoch\", y=[\"train_loss\", \"val_loss\"], figsize=(7,4), title=\"Training curve\")\n",
    "plt.show()"
